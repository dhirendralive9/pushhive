# PushHive Configuration
PORT=3000
MONGODB_URI=mongodb://localhost:27017/pushhive
SESSION_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_HEX
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@example.com
NODE_ENV=production

# Redis (used for job queue, caching)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Worker configuration
WORKER_CONCURRENCY=10
WORKER_RATE_LIMIT=50

# Cloudflare Turnstile (optional — leave empty to disable)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
