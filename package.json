{
  "name": "pushhive",
  "version": "2.0.0",
  "description": "Self-hosted open source web push notification system",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "worker": "node worker.js",
    "dev": "nodemon server.js",
    "health": "node -e \"fetch('http://localhost:'+(process.env.PORT||3000)+'/health').then(r=>r.json()).then(d=>{console.log(d);process.exit(d.status==='ok'?0:1)}).catch(e=>{console.error(e);process.exit(1)})\""
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "bullmq": "^5.12.0",
    "connect-mongo": "^5.1.0",
    "csrf-sync": "^4.0.3",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.4.0",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "mongoose": "^8.6.0",
    "multer": "^1.4.5-lts.1",
    "validator": "^13.12.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "license": "MIT"
}
