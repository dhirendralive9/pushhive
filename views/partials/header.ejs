<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
  <title><%= pageTitle %> — PushHive</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>

<button class="mobile-toggle" onclick="toggleSidebar()" aria-label="Menu">&#9776;</button>
<div class="mobile-overlay" onclick="toggleSidebar()"></div>

<nav class="sidebar" id="sidebar">
  <div class="sidebar-brand">
    <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect width="28" height="28" rx="6" fill="#6366f1"/><path d="M8 14l4 4 8-8" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    <span>PushHive</span>
  </div>
  <div class="sidebar-nav">
    <a href="/dashboard" class="nav-item<%= activePage === 'dashboard' ? ' active' : '' %>">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
      Dashboard
    </a>
    <% if (typeof canManageSites !== 'undefined' && canManageSites) { %>
    <a href="/dashboard/sites" class="nav-item<%= activePage === 'sites' ? ' active' : '' %>">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
      Sites
    </a>
    <% } %>
    <a href="/dashboard/subscribers" class="nav-item<%= activePage === 'subscribers' ? ' active' : '' %>">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
      Subscribers
    </a>
    <a href="/dashboard/segments" class="nav-item<%= activePage === 'segments' ? ' active' : '' %>">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M8 12h8M12 8v8"/></svg>
      Segments
    </a>
    <% if (typeof canCreateCampaigns !== 'undefined' && canCreateCampaigns) { %>
    <a href="/dashboard/campaigns" class="nav-item<%= activePage === 'campaigns' ? ' active' : '' %>">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
      Campaigns
    </a>
    <a href="/dashboard/automations" class="nav-item<%= activePage === 'automations' ? ' active' : '' %>">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.49 8.49l2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.49-8.49l2.83-2.83"/></svg>
      Automations
    </a>
    <% } %>
    <a href="/dashboard/analytics" class="nav-item<%= activePage === 'analytics' ? ' active' : '' %>">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 20V10M12 20V4M6 20v-6"/></svg>
      Analytics
    </a>
    <% if (typeof canManageSites !== 'undefined' && canManageSites) { %>
    <a href="/dashboard/queue" class="nav-item<%= activePage === 'queue' ? ' active' : '' %>">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
      Queue
    </a>
    <% } %>
    <% if (typeof canManageWebhooks !== 'undefined' && canManageWebhooks) { %>
    <a href="/dashboard/webhooks" class="nav-item<%= activePage === 'webhooks' ? ' active' : '' %>">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
      Webhooks
    </a>
    <% } %>
    <% if (typeof canManageRss !== 'undefined' && canManageRss) { %>
    <a href="/dashboard/rss" class="nav-item<%= activePage === 'rss' ? ' active' : '' %>">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 11a9 9 0 019 9"/><path d="M4 4a16 16 0 0116 16"/><circle cx="5" cy="19" r="1"/></svg>
      RSS Feeds
    </a>
    <% } %>
    <% if (typeof canManageUsers !== 'undefined' && canManageUsers) { %>
    <a href="/dashboard/team" class="nav-item<%= activePage === 'team' ? ' active' : '' %>">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197"/></svg>
      Team
    </a>
    <% } %>
    <a href="/dashboard/settings" class="nav-item<%= activePage === 'settings' ? ' active' : '' %>">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v2m0 18v2m-9-11h2m18 0h2m-3.3-6.7l-1.4 1.4M4.7 19.3l-1.4 1.4m0-15.4l1.4 1.4m14.2 14.2l1.4 1.4"/></svg>
      Settings
    </a>
    <a href="/dashboard/api-docs" class="nav-item<%= activePage === 'api-docs' ? ' active' : '' %>">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"/></svg>
      API Docs
    </a>
  </div>
  <div class="sidebar-footer">
    <div class="admin-info">
      <span class="admin-avatar"><%= admin.name.charAt(0).toUpperCase() %></span>
      <span class="admin-name"><%= admin.name %></span>
    </div>
    <a href="/auth/logout" class="nav-item logout">Logout</a>
    <div style="padding:8px 12px;margin-top:8px;border-top:1px solid var(--border);">
      <span class="text-xs text-muted">PushHive v<%= typeof appVersion !== 'undefined' ? appVersion : '1.1.0' %></span>
    </div>
  </div>
</nav>

<main class="content">
  <% if (typeof success !== 'undefined' && success) { %>
  <div class="alert alert-success"><%= success %></div>
  <% } %>
  <% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-error"><%= error %></div>
  <% } %>
