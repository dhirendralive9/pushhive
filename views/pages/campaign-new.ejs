<%- include('../partials/header', { pageTitle: 'New Campaign', activePage: 'campaigns' }) %>

<div class="page-header">
  <h1>New Campaign</h1>
  <a href="/dashboard/campaigns" class="btn btn-outline">&larr; Back</a>
</div>

<form method="POST" action="/dashboard/campaigns">
  <div class="card">
    <div class="card-header">
      <span class="card-title">Notification Content</span>
    </div>

    <div class="form-group">
      <label class="form-label">Site *</label>
      <select name="siteId" class="form-select" required>
        <option value="">Select a site</option>
        <% sites.forEach(function(s) { %>
        <option value="<%= s._id %>"><%= s.name %> — <%= s.domain %></option>
        <% }) %>
      </select>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label class="form-label">Title * <span class="text-muted">(max 100)</span></label>
        <input type="text" name="title" class="form-input" placeholder="Check out our new feature!" maxlength="100" required>
      </div>
      <div class="form-group">
        <label class="form-label">Click URL *</label>
        <input type="url" name="url" class="form-input" placeholder="https://example.com/page" required>
      </div>
    </div>

    <div class="form-group">
      <label class="form-label">Body * <span class="text-muted">(max 250)</span></label>
      <textarea name="body" class="form-textarea" placeholder="We've just launched something exciting..." maxlength="250" required></textarea>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label class="form-label">Icon URL</label>
        <input type="url" name="icon" class="form-input" placeholder="https://example.com/icon.png">
        <p class="form-help">192x192 PNG recommended. Leave blank for site default.</p>
      </div>
      <div class="form-group">
        <label class="form-label">Large Image URL</label>
        <input type="url" name="image" class="form-input" placeholder="https://example.com/banner.jpg">
        <p class="form-help">Optional hero image shown in expanded notification.</p>
      </div>
    </div>
  </div>

  <!-- Action Buttons -->
  <div class="card">
    <div class="card-header">
      <span class="card-title">Action Buttons <span class="text-muted text-sm">(optional, max 2)</span></span>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label class="form-label">Button 1 Title</label>
        <input type="text" name="action1Title" class="form-input" placeholder="Learn More">
      </div>
      <div class="form-group">
        <label class="form-label">Button 1 URL</label>
        <input type="url" name="action1Url" class="form-input" placeholder="https://example.com/learn">
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label class="form-label">Button 2 Title</label>
        <input type="text" name="action2Title" class="form-input" placeholder="Dismiss">
      </div>
      <div class="form-group">
        <label class="form-label">Button 2 URL</label>
        <input type="url" name="action2Url" class="form-input" placeholder="https://example.com">
      </div>
    </div>
  </div>

  <!-- UTM Parameters -->
  <div class="card">
    <div class="card-header">
      <span class="card-title">UTM Parameters</span>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label class="form-label">utm_source</label>
        <input type="text" name="utmSource" class="form-input" value="pushhive" placeholder="pushhive">
      </div>
      <div class="form-group">
        <label class="form-label">utm_medium</label>
        <input type="text" name="utmMedium" class="form-input" value="web_push" placeholder="web_push">
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label class="form-label">utm_campaign</label>
        <input type="text" name="utmCampaign" class="form-input" placeholder="spring_sale">
      </div>
      <div class="form-group">
        <label class="form-label">utm_content</label>
        <input type="text" name="utmContent" class="form-input" placeholder="variant_a">
      </div>
    </div>
    <div class="form-group">
      <label class="form-label">utm_term</label>
      <input type="text" name="utmTerm" class="form-input" placeholder="optional">
    </div>
  </div>

  <!-- Targeting -->
  <div class="card">
    <div class="card-header">
      <span class="card-title">Targeting</span>
    </div>
    <div class="form-group">
      <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
        <input type="radio" name="targetAll" value="true" checked onchange="toggleTargeting('all')">
        <span class="form-label" style="margin:0;">All subscribers</span>
      </label>
    </div>
    <div class="form-group">
      <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
        <input type="radio" name="targetAll" value="false" onchange="toggleTargeting('tags')">
        <span class="form-label" style="margin:0;">By tags</span>
      </label>
    </div>
    <% if (typeof segments !== 'undefined' && segments.length > 0) { %>
    <div class="form-group">
      <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
        <input type="radio" name="targetAll" value="segment" onchange="toggleTargeting('segment')">
        <span class="form-label" style="margin:0;">By segment</span>
      </label>
    </div>
    <% } %>

    <div id="target-tags" style="display:none;">
      <div class="form-group">
        <label class="form-label">Tags (comma separated)</label>
        <input type="text" name="targetTags" class="form-input" placeholder="vip, premium, returning">
      </div>
    </div>

    <% if (typeof segments !== 'undefined' && segments.length > 0) { %>
    <div id="target-segment" style="display:none;">
      <div class="form-group">
        <label class="form-label">Select Segment</label>
        <select name="targetSegment" class="form-select">
          <option value="">Choose a segment...</option>
          <% segments.forEach(function(seg) { %>
          <option value="<%= seg._id %>"><%= seg.name %> — ~<%= (seg.estimatedCount || 0).toLocaleString() %> subscribers (<%= seg.siteId ? seg.siteId.name : '' %>)</option>
          <% }) %>
        </select>
        <p class="form-help"><a href="/dashboard/segments" style="color:var(--primary-hover)">Manage segments</a></p>
      </div>
    </div>
    <% } %>
  </div>

  <script>
  function toggleTargeting(mode) {
    document.getElementById('target-tags').style.display = mode === 'tags' ? 'block' : 'none';
    var segEl = document.getElementById('target-segment');
    if (segEl) segEl.style.display = mode === 'segment' ? 'block' : 'none';
  }
  </script>

  <!-- A/B Testing -->
  <div class="card">
    <div class="card-header">
      <span class="card-title">A/B Testing <span class="text-muted text-sm">(optional)</span></span>
    </div>
    <div class="form-group">
      <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
        <input type="checkbox" name="abEnabled" id="abEnabled" onchange="toggleAB(this.checked)">
        <span class="form-label" style="margin:0;">Enable A/B testing</span>
      </label>
      <p class="form-help">Test two notification variants on a small group, then auto-send the winner to everyone else.</p>
    </div>

    <div id="ab-fields" style="display:none;">
      <div style="background:var(--bg-input);border:1px solid var(--border);border-radius:var(--radius-sm);padding:16px;margin-bottom:16px;">
        <p class="text-sm" style="margin-bottom:12px;color:#fff;font-weight:500;">Variant A</p>
        <p class="text-sm text-muted" style="margin-bottom:8px;">Uses the title and body from above (Notification Content section).</p>
      </div>

      <div style="background:var(--bg-input);border:1px solid var(--border);border-radius:var(--radius-sm);padding:16px;margin-bottom:16px;">
        <p class="text-sm" style="margin-bottom:12px;color:#fff;font-weight:500;">Variant B</p>
        <div class="form-group">
          <label class="form-label">Title B</label>
          <input type="text" name="abTitleB" class="form-input" placeholder="Alternative title" maxlength="100">
        </div>
        <div class="form-group">
          <label class="form-label">Body B</label>
          <textarea name="abBodyB" class="form-textarea" placeholder="Alternative notification body" maxlength="250"></textarea>
        </div>
        <div class="form-group">
          <label class="form-label">Icon B (optional)</label>
          <input type="url" name="abIconB" class="form-input" placeholder="Leave empty to use same icon">
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Test group size</label>
          <select name="abTestPercentage" class="form-select">
            <option value="10">10% (5% per variant)</option>
            <option value="20" selected>20% (10% per variant)</option>
            <option value="30">30% (15% per variant)</option>
            <option value="40">40% (20% per variant)</option>
            <option value="50">50% (25% per variant)</option>
          </select>
          <p class="form-help">Remaining subscribers will receive the winning variant.</p>
        </div>
        <div class="form-group">
          <label class="form-label">Wait before picking winner</label>
          <select name="abWaitHours" class="form-select">
            <option value="1">1 hour</option>
            <option value="2">2 hours</option>
            <option value="4" selected>4 hours</option>
            <option value="8">8 hours</option>
            <option value="12">12 hours</option>
            <option value="24">24 hours</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Winner decided by</label>
        <select name="abWinnerMetric" class="form-select" style="max-width:200px;">
          <option value="ctr" selected>Click-through rate (CTR)</option>
          <option value="clicks">Total clicks</option>
        </select>
      </div>
    </div>
  </div>

  <!-- Scheduling -->
  <div class="card">
    <div class="card-header">
      <span class="card-title">Schedule</span>
    </div>
    <div class="form-group">
      <label class="form-label">Schedule for later (optional)</label>
      <input type="datetime-local" name="scheduledAt" class="form-input">
      <p class="form-help">Leave empty to save as draft. You can send it manually from the campaigns list.</p>
    </div>
  </div>

  <div class="flex gap-8">
    <button type="submit" class="btn btn-primary">Create Campaign</button>
    <a href="/dashboard/campaigns" class="btn btn-outline">Cancel</a>
  </div>
</form>

<script>
function toggleAB(enabled) {
  document.getElementById('ab-fields').style.display = enabled ? 'block' : 'none';
}
</script>

<%- include('../partials/footer') %>
