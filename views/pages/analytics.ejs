<%- include('../partials/header', { pageTitle: 'Analytics', activePage: 'analytics' }) %>

<div class="page-header">
  <h1>Analytics</h1>
</div>

<!-- Filters -->
<div class="card">
  <form method="GET" action="/dashboard/analytics" class="flex gap-16" style="align-items:flex-end;flex-wrap:wrap;">
    <div class="form-group" style="margin-bottom:0;min-width:160px;">
      <label class="form-label">Site</label>
      <select name="siteId" class="form-select">
        <option value="">All Sites</option>
        <% sites.forEach(function(s) { %>
        <option value="<%= s._id %>" <%= filters.siteId === s._id.toString() ? 'selected' : '' %>><%= s.name %></option>
        <% }) %>
      </select>
    </div>
    <div class="form-group" style="margin-bottom:0;min-width:120px;">
      <label class="form-label">Period</label>
      <select name="days" class="form-select">
        <option value="7" <%= filters.days === '7' ? 'selected' : '' %>>Last 7 days</option>
        <option value="30" <%= filters.days === '30' || !filters.days ? 'selected' : '' %>>Last 30 days</option>
        <option value="90" <%= filters.days === '90' ? 'selected' : '' %>>Last 90 days</option>
      </select>
    </div>
    <button type="submit" class="btn btn-primary" style="margin-bottom:0;">Apply</button>
  </form>
</div>

<!-- Event Overview -->
<div class="stats-grid">
  <% var delivered = 0, clicked = 0, dismissed = 0, failed = 0;
     eventBreakdown.forEach(function(e) {
       if (e._id === 'delivered') delivered = e.count;
       if (e._id === 'clicked') clicked = e.count;
       if (e._id === 'dismissed') dismissed = e.count;
       if (e._id === 'failed') failed = e.count;
     }); %>
  <div class="stat-card">
    <div class="stat-label">Delivered</div>
    <div class="stat-value success"><%= delivered.toLocaleString() %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Clicked</div>
    <div class="stat-value primary"><%= clicked.toLocaleString() %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Dismissed</div>
    <div class="stat-value warning"><%= dismissed.toLocaleString() %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Failed</div>
    <div class="stat-value" style="color:var(--danger)"><%= failed.toLocaleString() %></div>
  </div>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
  <!-- Subscriber Growth -->
  <div class="card">
    <div class="card-header"><span class="card-title">Subscriber Growth</span></div>
    <% if (subGrowth.length === 0) { %>
      <p class="text-muted text-sm">No data for this period.</p>
    <% } else { %>
    <canvas id="growthChart" height="220"></canvas>
    <% } %>
  </div>

  <!-- Browser Distribution -->
  <div class="card">
    <div class="card-header"><span class="card-title">Browser Distribution</span></div>
    <% if (browserDist.length === 0) { %>
      <p class="text-muted text-sm">No subscriber data.</p>
    <% } else { %>
    <canvas id="browserDistChart" height="220"></canvas>
    <% } %>
  </div>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:20px;">
  <!-- Device Distribution -->
  <div class="card">
    <div class="card-header"><span class="card-title">Device Distribution</span></div>
    <% if (deviceDist.length === 0) { %>
      <p class="text-muted text-sm">No subscriber data.</p>
    <% } else { %>
    <canvas id="deviceDistChart" height="220"></canvas>
    <% } %>
  </div>

  <!-- UTM Performance -->
  <div class="card">
    <div class="card-header"><span class="card-title">UTM Campaign Performance</span></div>
    <% if (utmPerformance.length === 0) { %>
      <p class="text-muted text-sm">No UTM click data for this period.</p>
    <% } else { %>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Source</th><th>Medium</th><th>Campaign</th><th>Clicks</th></tr></thead>
        <tbody>
          <% utmPerformance.forEach(function(u) { %>
          <tr>
            <td><%= u._id.source || '—' %></td>
            <td><%= u._id.medium || '—' %></td>
            <td><strong><%= u._id.campaign || '—' %></strong></td>
            <td><%= u.clicks %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
<script>
  var colors = ['#6366f1','#22c55e','#f59e0b','#ef4444','#ec4899','#06b6d4','#8b5cf6','#f97316'];

  var growthData = <%- JSON.stringify(subGrowth) %>;
  if (growthData.length && document.getElementById('growthChart')) {
    new Chart(document.getElementById('growthChart'), {
      type: 'line',
      data: {
        labels: growthData.map(function(d) { return d._id.slice(5); }),
        datasets: [{
          label: 'New Subscribers',
          data: growthData.map(function(d) { return d.count; }),
          borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,0.1)',
          fill: true, tension: 0.3, pointRadius: 3
        }]
      },
      options: {
        responsive: true, plugins: { legend: { display: false } },
        scales: {
          y: { beginAtZero: true, ticks: { color: '#71717a' }, grid: { color: '#2a2d38' } },
          x: { ticks: { color: '#71717a' }, grid: { display: false } }
        }
      }
    });
  }

  var browserDistData = <%- JSON.stringify(browserDist) %>;
  if (browserDistData.length && document.getElementById('browserDistChart')) {
    new Chart(document.getElementById('browserDistChart'), {
      type: 'doughnut',
      data: {
        labels: browserDistData.map(function(d) { return d._id || 'Unknown'; }),
        datasets: [{ data: browserDistData.map(function(d) { return d.count; }), backgroundColor: colors }]
      },
      options: { responsive: true, plugins: { legend: { position: 'bottom', labels: { color: '#71717a' } } } }
    });
  }

  var deviceDistData = <%- JSON.stringify(deviceDist) %>;
  if (deviceDistData.length && document.getElementById('deviceDistChart')) {
    new Chart(document.getElementById('deviceDistChart'), {
      type: 'doughnut',
      data: {
        labels: deviceDistData.map(function(d) { return d._id || 'Unknown'; }),
        datasets: [{ data: deviceDistData.map(function(d) { return d.count; }), backgroundColor: colors.slice(2) }]
      },
      options: { responsive: true, plugins: { legend: { position: 'bottom', labels: { color: '#71717a' } } } }
    });
  }
</script>

<%- include('../partials/footer') %>
