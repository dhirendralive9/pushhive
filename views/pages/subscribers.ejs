<%- include('../partials/header', { pageTitle: 'Subscribers', activePage: 'subscribers' }) %>

<div class="page-header">
  <h1>Subscribers (<%= total.toLocaleString() %>)</h1>
</div>

<!-- Filters -->
<div class="card">
  <form method="GET" action="/dashboard/subscribers" class="flex gap-16" style="align-items:flex-end;flex-wrap:wrap;">
    <div class="form-group" style="margin-bottom:0;min-width:160px;">
      <label class="form-label">Site</label>
      <select name="siteId" class="form-select">
        <option value="">All Sites</option>
        <% sites.forEach(function(s) { %>
        <option value="<%= s._id %>" <%= filters.siteId === s._id.toString() ? 'selected' : '' %>><%= s.name %></option>
        <% }) %>
      </select>
    </div>
    <div class="form-group" style="margin-bottom:0;min-width:120px;">
      <label class="form-label">Device</label>
      <select name="device" class="form-select">
        <option value="">All</option>
        <option value="desktop" <%= filters.device === 'desktop' ? 'selected' : '' %>>Desktop</option>
        <option value="mobile" <%= filters.device === 'mobile' ? 'selected' : '' %>>Mobile</option>
        <option value="tablet" <%= filters.device === 'tablet' ? 'selected' : '' %>>Tablet</option>
      </select>
    </div>
    <div class="form-group" style="margin-bottom:0;min-width:120px;">
      <label class="form-label">Browser</label>
      <input type="text" name="browser" class="form-input" placeholder="Chrome" value="<%= filters.browser || '' %>">
    </div>
    <div class="form-group" style="margin-bottom:0;min-width:120px;">
      <label class="form-label">Tag</label>
      <input type="text" name="tag" class="form-input" placeholder="vip" value="<%= filters.tag || '' %>">
    </div>
    <button type="submit" class="btn btn-primary" style="margin-bottom:0;">Filter</button>
    <a href="/dashboard/subscribers" class="btn btn-outline" style="margin-bottom:0;">Clear</a>
  </form>
</div>

<!-- Subscribers Table -->
<div class="card">
  <% if (subscribers.length === 0) { %>
    <p class="text-muted text-sm">No subscribers found matching your filters.</p>
  <% } else { %>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Browser</th>
          <th>OS</th>
          <th>Device</th>
          <th>Site</th>
          <th>Tags</th>
          <th>Clicks</th>
          <th>Last Active</th>
          <th>Subscribed</th>
        </tr>
      </thead>
      <tbody>
        <% subscribers.forEach(function(sub) { %>
        <tr>
          <td><%= sub.browser %> <span class="text-muted text-xs"><%= sub.browserVersion %></span></td>
          <td><%= sub.os %></td>
          <td><span class="badge badge-primary"><%= sub.device %></span></td>
          <td class="text-muted"><%= sub.siteId ? sub.siteId.name : '—' %></td>
          <td>
            <% if (sub.tags && sub.tags.length > 0) { %>
              <% sub.tags.forEach(function(t) { %>
              <span class="badge badge-warning" style="margin-right:2px;"><%= t %></span>
              <% }) %>
            <% } else { %>
              <span class="text-muted">—</span>
            <% } %>
          </td>
          <td><%= sub.totalClicks %></td>
          <td class="text-muted text-xs"><%= sub.lastActive ? new Date(sub.lastActive).toLocaleDateString() : '—' %></td>
          <td class="text-muted text-xs"><%= new Date(sub.createdAt).toLocaleDateString() %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  <% if (totalPages > 1) { %>
  <div class="pagination">
    <% if (page > 1) { %>
      <a href="/dashboard/subscribers?page=<%= page - 1 %>&siteId=<%= filters.siteId || '' %>&device=<%= filters.device || '' %>&browser=<%= filters.browser || '' %>&tag=<%= filters.tag || '' %>">&laquo; Prev</a>
    <% } %>
    <% for (var i = 1; i <= totalPages; i++) { %>
      <% if (i === page) { %>
        <span class="current"><%= i %></span>
      <% } else if (Math.abs(i - page) <= 2 || i === 1 || i === totalPages) { %>
        <a href="/dashboard/subscribers?page=<%= i %>&siteId=<%= filters.siteId || '' %>&device=<%= filters.device || '' %>&browser=<%= filters.browser || '' %>&tag=<%= filters.tag || '' %>"><%= i %></a>
      <% } %>
    <% } %>
    <% if (page < totalPages) { %>
      <a href="/dashboard/subscribers?page=<%= page + 1 %>&siteId=<%= filters.siteId || '' %>&device=<%= filters.device || '' %>&browser=<%= filters.browser || '' %>&tag=<%= filters.tag || '' %>">Next &raquo;</a>
    <% } %>
  </div>
  <% } %>
  <% } %>
</div>

<%- include('../partials/footer') %>
