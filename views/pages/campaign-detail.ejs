<%- include('../partials/header', { pageTitle: campaign.title, activePage: 'campaigns' }) %>

<div class="page-header">
  <h1><%= campaign.title %></h1>
  <div class="flex gap-8">
    <a href="/dashboard/campaigns" class="btn btn-outline">&larr; Back</a>
    <form method="POST" action="/dashboard/campaigns/<%= campaign._id %>/duplicate" style="display:inline;">
      <button type="submit" class="btn btn-outline btn-sm">Duplicate</button>
    </form>
    <form method="POST" action="/dashboard/campaigns/<%= campaign._id %>/delete" style="display:inline;">
      <button type="submit" class="btn btn-danger btn-sm" data-confirm="Delete this campaign and its analytics? This cannot be undone.">Delete</button>
    </form>
  </div>
</div>

<!-- Campaign Stats -->
<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-label">Targeted</div>
    <div class="stat-value"><%= campaign.stats.targeted.toLocaleString() %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Delivered</div>
    <div class="stat-value success"><%= campaign.stats.delivered.toLocaleString() %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Clicked</div>
    <div class="stat-value primary"><%= campaign.stats.clicked.toLocaleString() %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">CTR</div>
    <div class="stat-value warning"><%= campaign.stats.sent > 0 ? ((campaign.stats.clicked / campaign.stats.sent) * 100).toFixed(1) + '%' : '0%' %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Failed</div>
    <div class="stat-value" style="color:var(--danger)"><%= campaign.stats.failed.toLocaleString() %></div>
  </div>
</div>

<!-- Campaign Details -->
<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
  <div class="card">
    <div class="card-header">
      <span class="card-title">Campaign Info</span>
      <span class="badge badge-<%= campaign.status === 'sent' ? 'success' : campaign.status === 'failed' ? 'danger' : 'primary' %>"><%= campaign.status %></span>
    </div>
    <table>
      <tr><td class="text-muted" style="width:120px;">Title</td><td><strong><%= campaign.title %></strong></td></tr>
      <tr><td class="text-muted">Body</td><td><%= campaign.body %></td></tr>
      <tr><td class="text-muted">URL</td><td><a href="<%= campaign.url %>" target="_blank" style="color:var(--primary-hover)"><%= campaign.url %></a></td></tr>
      <tr><td class="text-muted">Site</td><td><%= campaign.siteId ? campaign.siteId.name : '—' %></td></tr>
      <tr><td class="text-muted">Sent At</td><td><%= campaign.sentAt ? new Date(campaign.sentAt).toLocaleString() : '—' %></td></tr>
    </table>
  </div>

  <div class="card">
    <div class="card-header">
      <span class="card-title">UTM Parameters</span>
    </div>
    <table>
      <tr><td class="text-muted" style="width:120px;">Source</td><td><code><%= campaign.utm.source || '—' %></code></td></tr>
      <tr><td class="text-muted">Medium</td><td><code><%= campaign.utm.medium || '—' %></code></td></tr>
      <tr><td class="text-muted">Campaign</td><td><code><%= campaign.utm.campaign || '—' %></code></td></tr>
      <tr><td class="text-muted">Term</td><td><code><%= campaign.utm.term || '—' %></code></td></tr>
      <tr><td class="text-muted">Content</td><td><code><%= campaign.utm.content || '—' %></code></td></tr>
    </table>
  </div>
</div>

<!-- A/B Test Results -->
<% if (campaign.abTest && campaign.abTest.enabled && campaign.abTest.variants && campaign.abTest.variants.length === 2) { %>
<div class="card mt-24">
  <div class="card-header">
    <span class="card-title">A/B Test Results</span>
    <% if (campaign.abTest.winnerVariant) { %>
      <span class="badge badge-success">Winner: Variant <%= campaign.abTest.winnerVariant %></span>
    <% } else if (campaign.abTest.status === 'testing' || campaign.status === 'ab_testing') { %>
      <span class="badge badge-warning">Testing in progress</span>
    <% } else if (campaign.status === 'ab_waiting') { %>
      <span class="badge badge-warning">Waiting for results (<%= campaign.abTest.waitHours %>h)</span>
    <% } %>
  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
    <% campaign.abTest.variants.forEach(function(v) {
      var isWinner = campaign.abTest.winnerVariant === v.name;
      var vCtr = v.stats.sent > 0 ? ((v.stats.clicked / v.stats.sent) * 100).toFixed(1) : '0.0';
    %>
    <div style="background:var(--bg-input);border:2px solid <%= isWinner ? 'var(--success)' : 'var(--border)' %>;border-radius:var(--radius);padding:20px;position:relative;">
      <% if (isWinner) { %>
      <span class="badge badge-success" style="position:absolute;top:12px;right:12px;">Winner</span>
      <% } %>
      <div style="font-size:16px;font-weight:600;color:#fff;margin-bottom:12px;">Variant <%= v.name %></div>
      <table>
        <tr><td class="text-muted text-sm" style="padding:4px 12px 4px 0;">Title</td><td class="text-sm"><strong><%= v.title %></strong></td></tr>
        <tr><td class="text-muted text-sm" style="padding:4px 12px 4px 0;">Body</td><td class="text-sm"><%= v.body %></td></tr>
      </table>
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-top:16px;">
        <div>
          <div class="text-xs text-muted" style="text-transform:uppercase;letter-spacing:0.05em;">Sent</div>
          <div style="font-size:20px;font-weight:700;color:#fff;"><%= (v.stats.sent || 0).toLocaleString() %></div>
        </div>
        <div>
          <div class="text-xs text-muted" style="text-transform:uppercase;letter-spacing:0.05em;">Clicked</div>
          <div style="font-size:20px;font-weight:700;color:var(--primary-hover);"><%= (v.stats.clicked || 0).toLocaleString() %></div>
        </div>
        <div>
          <div class="text-xs text-muted" style="text-transform:uppercase;letter-spacing:0.05em;">CTR</div>
          <div style="font-size:20px;font-weight:700;color:<%= isWinner ? 'var(--success)' : '#fff' %>;"><%= vCtr %>%</div>
        </div>
        <div>
          <div class="text-xs text-muted" style="text-transform:uppercase;letter-spacing:0.05em;">Failed</div>
          <div style="font-size:20px;font-weight:700;color:var(--danger);"><%= (v.stats.failed || 0).toLocaleString() %></div>
        </div>
      </div>
    </div>
    <% }) %>
  </div>

  <div style="background:var(--bg-input);border:1px solid var(--border);border-radius:var(--radius-sm);padding:12px;">
    <table>
      <tr><td class="text-muted text-sm" style="padding:2px 12px 2px 0;">Test group</td><td class="text-sm"><%= campaign.abTest.testPercentage %>% of subscribers</td></tr>
      <tr><td class="text-muted text-sm" style="padding:2px 12px 2px 0;">Wait time</td><td class="text-sm"><%= campaign.abTest.waitHours %> hours</td></tr>
      <tr><td class="text-muted text-sm" style="padding:2px 12px 2px 0;">Winner metric</td><td class="text-sm"><%= campaign.abTest.winnerMetric === 'ctr' ? 'Click-through rate' : 'Total clicks' %></td></tr>
      <% if (campaign.abTest.winnerSentAt) { %>
      <tr><td class="text-muted text-sm" style="padding:2px 12px 2px 0;">Winner sent at</td><td class="text-sm"><%= new Date(campaign.abTest.winnerSentAt).toLocaleString() %></td></tr>
      <% } %>
    </table>
  </div>
</div>
<% } %>

<!-- Click Analytics -->
<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:20px;">
  <div class="card">
    <div class="card-header">
      <span class="card-title">Clicks by Browser</span>
    </div>
    <% if (clicksByBrowser.length === 0) { %>
      <p class="text-muted text-sm">No click data yet.</p>
    <% } else { %>
    <canvas id="browserChart" height="200"></canvas>
    <% } %>
  </div>

  <div class="card">
    <div class="card-header">
      <span class="card-title">Clicks by Device</span>
    </div>
    <% if (clicksByDevice.length === 0) { %>
      <p class="text-muted text-sm">No click data yet.</p>
    <% } else { %>
    <canvas id="deviceChart" height="200"></canvas>
    <% } %>
  </div>
</div>

<% if (clickTimeline.length > 0) { %>
<div class="card mt-24">
  <div class="card-header">
    <span class="card-title">Click Timeline</span>
  </div>
  <canvas id="timelineChart" height="150"></canvas>
</div>
<% } %>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
<script>
  var colors = ['#6366f1','#22c55e','#f59e0b','#ef4444','#ec4899','#06b6d4','#8b5cf6'];
  var browserData = <%- JSON.stringify(clicksByBrowser) %>;
  var deviceData = <%- JSON.stringify(clicksByDevice) %>;
  var timelineData = <%- JSON.stringify(clickTimeline) %>;

  if (browserData.length && document.getElementById('browserChart')) {
    new Chart(document.getElementById('browserChart'), {
      type: 'doughnut',
      data: {
        labels: browserData.map(function(d) { return d._id || 'Unknown'; }),
        datasets: [{ data: browserData.map(function(d) { return d.count; }), backgroundColor: colors }]
      },
      options: { responsive: true, plugins: { legend: { position: 'bottom', labels: { color: '#71717a' } } } }
    });
  }

  if (deviceData.length && document.getElementById('deviceChart')) {
    new Chart(document.getElementById('deviceChart'), {
      type: 'doughnut',
      data: {
        labels: deviceData.map(function(d) { return d._id || 'Unknown'; }),
        datasets: [{ data: deviceData.map(function(d) { return d.count; }), backgroundColor: colors.slice(3) }]
      },
      options: { responsive: true, plugins: { legend: { position: 'bottom', labels: { color: '#71717a' } } } }
    });
  }

  if (timelineData.length && document.getElementById('timelineChart')) {
    new Chart(document.getElementById('timelineChart'), {
      type: 'line',
      data: {
        labels: timelineData.map(function(d) { return d._id; }),
        datasets: [{
          label: 'Clicks',
          data: timelineData.map(function(d) { return d.count; }),
          borderColor: '#6366f1',
          backgroundColor: 'rgba(99,102,241,0.1)',
          fill: true,
          tension: 0.3
        }]
      },
      options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: {
          y: { beginAtZero: true, ticks: { color: '#71717a' }, grid: { color: '#2a2d38' } },
          x: { ticks: { color: '#71717a', maxTicksLimit: 12 }, grid: { display: false } }
        }
      }
    });
  }
</script>

<%- include('../partials/footer') %>
