<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' — ' : '' %>PushHive</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
  <% if (admin) { %>
  <nav class="sidebar">
    <div class="sidebar-brand">
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect width="28" height="28" rx="6" fill="#4F46E5"/><path d="M8 14l4 4 8-8" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <span>PushHive</span>
    </div>
    <div class="sidebar-nav">
      <a href="/dashboard" class="nav-item<%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? ' active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        Dashboard
      </a>
      <a href="/dashboard/sites" class="nav-item<%= typeof activePage !== 'undefined' && activePage === 'sites' ? ' active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
        Sites
      </a>
      <a href="/dashboard/subscribers" class="nav-item<%= typeof activePage !== 'undefined' && activePage === 'subscribers' ? ' active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
        Subscribers
      </a>
      <a href="/dashboard/campaigns" class="nav-item<%= typeof activePage !== 'undefined' && activePage === 'campaigns' ? ' active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
        Campaigns
      </a>
      <a href="/dashboard/analytics" class="nav-item<%= typeof activePage !== 'undefined' && activePage === 'analytics' ? ' active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 20V10M12 20V4M6 20v-6"/></svg>
        Analytics
      </a>
      <a href="/dashboard/settings" class="nav-item<%= typeof activePage !== 'undefined' && activePage === 'settings' ? ' active' : '' %>">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v2m0 18v2m-9-11h2m18 0h2m-3.3-6.7l-1.4 1.4M4.7 19.3l-1.4 1.4m0-15.4l1.4 1.4m14.2 14.2l1.4 1.4"/></svg>
        Settings
      </a>
    </div>
    <div class="sidebar-footer">
      <div class="admin-info">
        <span class="admin-avatar"><%= admin.name.charAt(0).toUpperCase() %></span>
        <span class="admin-name"><%= admin.name %></span>
      </div>
      <a href="/auth/logout" class="nav-item logout">Logout</a>
    </div>
  </nav>
  <% } %>

  <main class="<%= admin ? 'content' : 'content-full' %>">
    <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success"><%= success %></div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-error"><%= error %></div>
    <% } %>
    <%- body %>
  </main>

  <script src="/js/dashboard.js"></script>
</body>
</html>
